# Скопируй в .env для локального запуска: cp .env.example .env

# Ключ Anthropic API — нужен ТОЛЬКО для фазы 2 (отклик: письмо + адаптация резюме).
# Фаза 1 (подборка вакансий) работает без него.
# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Модель Claude для откликов (по умолчанию claude-opus-4-8). Для экономии — claude-sonnet-4-6.
JOBBOT_MODEL=claude-opus-4-8

# Минимальный балл соответствия (0..100), ниже которого вакансия не попадает в подборку.
JOBBOT_MIN_SCORE=25
