# Скопируй в .env для локального запуска: cp .env.example .env

# Ключ Anthropic API — нужен для генерации сопроводительных писем и адаптации резюме.
# Получить: https://console.anthropic.com/  (без него бот всё равно соберёт и оценит вакансии,
# но не будет готовить отклики).
ANTHROPIC_API_KEY=

# Модель Claude (по умолчанию claude-opus-4-8). Для экономии можно claude-sonnet-4-6.
JOBBOT_MODEL=claude-opus-4-8

# Сколько лучших вакансий за запуск готовить под отклик (письмо + адаптация резюме).
JOBBOT_TOP_N=5

# Минимальный балл соответствия (0..100), ниже которого вакансия не попадает в отчёт.
JOBBOT_MIN_SCORE=25
