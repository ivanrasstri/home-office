# Скопируй в .env для локального запуска: cp .env.example .env

# --- Claude (нужен для откликов / фазы 2) -----------------------------------
# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Модель Claude (по умолчанию claude-opus-4-8). Для экономии — claude-sonnet-4-6.
JOBBOT_MODEL=claude-opus-4-8

# Минимальный балл соответствия (0..100), ниже которого вакансия не попадает в подборку.
JOBBOT_MIN_SCORE=25

# --- Telegram-бот (интерактивный режим) -------------------------------------
# Токен от @BotFather (обязательно для бота).
TELEGRAM_BOT_TOKEN=
# Разрешённые chat_id через запятую. Если задано — бот реагирует только на них
# (рекомендуется). Если пусто — доверяет первому, кто напишет /start.
# Свой chat_id бот покажет в ответ на /start.
TELEGRAM_CHAT_ID=
# Авто-подборка по будням (true/false) и час по UTC (6 ≈ 11:00 Ташкент).
JOBBOT_AUTO_SEARCH=true
JOBBOT_DAILY_HOUR_UTC=6

# --- Хранилище состояния -----------------------------------------------------
# Каталог для seen.json / shortlist.json / подписчиков. На Railway укажи путь
# к примонтированному Volume, чтобы данные не терялись между перезапусками.
JOBBOT_DATA_DIR=
